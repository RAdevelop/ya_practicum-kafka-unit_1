PRODUCER_BOOTSTRAP_SERVERS="kafka-b-1:9092,kafka-b-2:9092,kafka-b-3:9092"
PRODUCER_ACKS="all"
PRODUCER_RETRIES=10
PRODUCER_RETRY_BACKOFF_MS=100
PRODUCER_ENABLE_IDEMPOTENCE=true
PRODUCER_FLUSH_TIMEOUT_MS=15000

CONSUMER_BOOTSTRAP_SERVERS="kafka-b-1:9092,kafka-b-2:9092,kafka-b-3:9092"
CONSUMER_GROUP_ID=""
CONSUMER_AUTO_OFFSET_RESET="earliest"
CONSUMER_ENABLE_AUTO_COMMIT=false
CONSUMER_FETCH_MIN_BYTES=1
CONSUMER_FETCH_MAX_WAIT_MS=100